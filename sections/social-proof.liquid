<style>
  :root {
    --sc-bg: #0a0a0f;
    --sc-bg2: #12121e;
    --sc-bg3: #16162a;
    --sc-bg4: #1c1c32;
    --sc-cyan: #0ea5e9;
    --sc-magenta: #ec4899;
    --sc-magenta-dark: #db2777;
    --sc-green: #10b981;
    --sc-red: #ef4444;
    --sc-muted: rgba(255, 255, 255, 0.55);
    --sc-white: #ffffff;
  }




  
    <style>
      .testimonial-video {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        margin-bottom: 24px;
      }

      .testimonial-video video {
        width: 100%;
        border-radius: 12px;
        max-width: 100%;
      }
    </style>

   

    {% if section.settings.video_testimonial %}
      <div class="testimonial-video">
        {{ section.settings.video_testimonial | video_tag: controls: true, autoplay: false }}
      </div>
    {% endif %}

    <div class="testimonial-card lupita-story">
      <p class="testimonial-quote">
  </div>
</section>

{% schema %}
{
  "name": "Social Proof",
  "settings": [
    {
      "type": "video",
      "id": "video_testimonial",
      "label": "Video testimonial (audio)"
    }
  ],
  "presets": [
    {
      "name": "Social Proof"
    }
  ]
}
{% endschema %}
